<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/card_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvVoyageName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voyage Name"
                android:textColor="@color/deep_sky_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvVoyageInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date -- 0 points"
                android:textColor="@color/text_medium_grey"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <ImageView
                android:id="@+id/ivView"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_view_voyage"
                android:tint="@color/text_dark_grey"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="View Map"/>

            <ImageView
                android:id="@+id/ivRename"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_rename"
                android:tint="@color/text_dark_grey"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Rename Voyage"/>

            <ImageView
                android:id="@+id/ivDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:tint="@color/red_error"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete Voyage"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>