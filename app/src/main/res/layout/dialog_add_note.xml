<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Note"
        android:textColor="#2196F3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <AutoCompleteTextView
        android:id="@+id/etNoteText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Note text (e.g. Speed breaker)"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <AutoCompleteTextView
        android:id="@+id/etNoteGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Group/Tag (e.g. Hazard)"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Icon"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">
        
        <RadioGroup
            android:id="@+id/rgIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <RadioButton
                android:id="@+id/rbIconMarker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/ic_note_marker"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:checked="true"/>
                
            <RadioButton
                android:id="@+id/rbIconSpeedbreaker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/ic_speedbreaker"
                android:padding="8dp"
                android:layout_marginEnd="8dp"/>
                
            <RadioButton
                android:id="@+id/rbIconTent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/ic_tent"
                android:padding="8dp"
                android:layout_marginEnd="8dp"/>
                
            <RadioButton
                android:id="@+id/rbIconDanger"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/ic_danger"
                android:padding="8dp"
                android:layout_marginEnd="8dp"/>
                
            <RadioButton
                android:id="@+id/rbIconFood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/ic_food"
                android:padding="8dp"
                android:layout_marginEnd="8dp"/>
        </RadioGroup>
    </HorizontalScrollView>

</LinearLayout>