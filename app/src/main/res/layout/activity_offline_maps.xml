<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    tools:context=".OfflineMapsActivity">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@color/sky_blue"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/text_dark_grey"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Offline Maps"
            android:textColor="@color/text_dark_grey"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnLoadMapFile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_add_note"
            android:tint="@color/text_dark_grey"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add Map File" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Offline Maps Only Switch Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <Switch
                        android:id="@+id/switchOfflineOnly"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Offline Maps Only"
                        android:textColor="@color/text_dark_grey"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Force the map to only use downloaded files"
                        android:textSize="12sp"
                        android:textColor="@color/text_medium_grey"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Downloaded Maps Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Downloaded Maps"
                android:textColor="@color/deep_sky_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:id="@+id/mapsListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No offline maps found."
                android:textColor="@color/text_medium_grey"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

            <!-- FAQ Section (collapsible) -->
            <TextView
                android:id="@+id/tvFaqToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How do I add maps?"
                android:textColor="@color/deep_sky_blue"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginStart="4dp"
                android:drawableEnd="@android:drawable/arrow_down_float"
                android:drawablePadding="8dp"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cvInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvInstructionSteps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. Open OpenAndroMaps or a similar vector map provider.\n2. Select your general region on the map.\n3. Browse through the map list and download the map for your region.\n4. Download the .map file only (ranges between 200MB to 2GB).\n5. You get a .zip file which you need to extract to get the .map file.\n6. Add that file here by clicking the + button in the header.\n7. You can enable the 'Offline Maps Only' option and add as many maps as you want."
                        android:textColor="@color/text_medium_grey"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>