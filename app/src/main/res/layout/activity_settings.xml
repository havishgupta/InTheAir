<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".SettingsActivity">
    
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E24"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offline Maps"
                        android:textColor="#4DB6AC"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <Switch
                        android:id="@+id/switchOfflineOnly"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Offline Maps Only"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="If disabled, online maps will load by default."
                        android:textSize="12sp"
                        android:textColor="#A0A0A0"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:id="@+id/tvCacheSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:text="Current Cache Size: Calculating..."
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnClearCache"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Clear Cached Tiles"
                        android:backgroundTint="#D32F2F"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnViewOffline"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Manage Offline Maps"
                        android:backgroundTint="#4DB6AC"
                        android:textColor="#121212" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E24"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Units"
                        android:textColor="#4DB6AC"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Speed Units -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:text="Speed"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgSpeedUnits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbSpeedKmh" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="km/h" android:checked="true"/>
                        <RadioButton android:id="@+id/rbSpeedKts" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Knots" />
                        <RadioButton android:id="@+id/rbSpeedMph" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="mph" />
                        <RadioButton android:id="@+id/rbSpeedMach" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mach" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="16dp"/>

                    <!-- Initial Zoom -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:text="Initial Zoom"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgInitialZoom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbZoomFar" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Far (10x)" />
                        <RadioButton android:id="@+id/rbZoomMedium" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medium (14x)" />
                        <RadioButton android:id="@+id/rbZoomClose" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Close (18x)" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="16dp"/>

                    <!-- Debug Mode -->
                    <Switch
                        android:id="@+id/switchDebugMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Debug Mode (Raw Data &amp; Compass)"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="16dp"/>

                    <!-- Altitude Units -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:text="Altitude"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgAltUnits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbAltM" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Meters" android:checked="true"/>
                        <RadioButton android:id="@+id/rbAltFt" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Feet" />
                        <RadioButton android:id="@+id/rbAltKm" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kilometers (km)" />
                        <RadioButton android:id="@+id/rbAltBk" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Burj Khalifa (bk)" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="16dp"/>

                    <!-- Climb Rate Units -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:text="Climb Rate"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgClimbUnits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbClimbMs" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m/s" android:checked="true"/>
                        <RadioButton android:id="@+id/rbClimbKmh" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="km/h" />
                        <RadioButton android:id="@+id/rbClimbFpm" android:textColor="#A0A0A0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ft/min" />
                    </RadioGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>