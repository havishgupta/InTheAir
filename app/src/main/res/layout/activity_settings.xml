<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".SettingsActivity">
    
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM CFG"
                android:textColor="#0FFFFF"
                android:textSize="28sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <!-- Core Operations Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#111111"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="> NAV_SYS"
                    android:textColor="#FF00FF"
                    android:fontFamily="monospace"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnDownloadRouteMap"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="[ INITIATE ROUTE DL ]"
                    android:backgroundTint="#000000"
                    android:textColor="#0FFFFF"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    app:strokeColor="#0FFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="0dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnViewOffline"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="[ ARCHIVE MGR ]"
                    android:backgroundTint="#000000"
                    android:textColor="#FF00FF"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    app:strokeColor="#FF00FF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="0dp"
                    android:layout_marginBottom="24dp"/>

                <Switch
                    android:id="@+id/switchOfflineOnly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FORCE_OFFLINE"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="// Restricts net operations"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:id="@+id/tvCacheSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#0FFFFF"
                    android:fontFamily="monospace"
                    android:text="CACHE_MEM: -- MB"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnClearCache"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="PURGE MEM"
                    android:backgroundTint="#FF0000"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    app:cornerRadius="0dp" />
            </LinearLayout>

            <!-- Metrics Configuration Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#111111"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="> SENSOR_UNITS"
                    android:textColor="#FF00FF"
                    android:fontFamily="monospace"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <!-- Speed Units -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:text="VELOCITY_MODE"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>
                
                <RadioGroup
                    android:id="@+id/rgSpeedUnits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <RadioButton android:id="@+id/rbSpeedKmh" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KM/H"/>
                    <RadioButton android:id="@+id/rbSpeedKts" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KNOTS" />
                    <RadioButton android:id="@+id/rbSpeedMph" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MPH" />
                    <RadioButton android:id="@+id/rbSpeedMach" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MACH" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="24dp"/>

                <!-- Altitude Units -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:text="ALTITUDE_MODE"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>
                
                <RadioGroup
                    android:id="@+id/rgAltUnits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <RadioButton android:id="@+id/rbAltM" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="METERS"/>
                    <RadioButton android:id="@+id/rbAltFt" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FEET" />
                    <RadioButton android:id="@+id/rbAltKm" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KILOMETERS" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="24dp"/>

                <!-- Climb Rate Units -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:text="V-SPEED_MODE"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>
                
                <RadioGroup
                    android:id="@+id/rgClimbUnits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <RadioButton android:id="@+id/rbClimbMs" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M/S"/>
                    <RadioButton android:id="@+id/rbClimbKmh" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KM/H" />
                    <RadioButton android:id="@+id/rbClimbFpm" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FT/MIN" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="24dp"/>

                <!-- Initial Zoom -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:text="DEF_ZOOM"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>
                
                <RadioGroup
                    android:id="@+id/rgInitialZoom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <RadioButton android:id="@+id/rbZoomFar" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10X [FAR]" />
                    <RadioButton android:id="@+id/rbZoomMedium" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14X [MED]" />
                    <RadioButton android:id="@+id/rbZoomClose" android:textColor="#0FFFFF" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18X [CLOSE]" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="24dp"/>

                <!-- Advanced -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="> DEV_TOOLS"
                    android:textColor="#FF0000"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <Switch
                    android:id="@+id/switchDebugMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HUD_OVERLAY"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>