<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    tools:context=".SettingsActivity">
    
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="@color/text_dark_grey"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- Routes Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/cloud_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Routes"
                        android:textColor="@color/deep_sky_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Container for recent routes -->
                    <LinearLayout
                        android:id="@+id/llRecentRoutes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnViewAllRoutes"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="View All Routes"
                        android:backgroundTint="@color/sky_blue"
                        android:textColor="@color/text_dark_grey"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Offline Maps -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/cloud_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offline Maps"
                        android:textColor="@color/deep_sky_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <Switch
                        android:id="@+id/switchOfflineOnly"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Offline Maps Only"
                        android:textColor="@color/text_dark_grey"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="If disabled, online maps will load by default."
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="24dp"/>

                    <Button
                        android:id="@+id/btnViewOffline"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Manage Offline Maps"
                        android:backgroundTint="@color/deep_sky_blue"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- OpenAndroMaps Link Instructions -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Download More Maps:"
                        android:textColor="@color/text_dark_grey"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    
                    <TextView
                        android:id="@+id/tvOpenAndroMapsLink"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="https://www.openandromaps.org/en/downloads/countrys-and-regions"
                        android:textColor="@color/deep_sky_blue"
                        android:autoLink="web"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Note: Maps are downloaded as .zip files. You must extract the .map file before importing."
                        android:textSize="12sp"
                        android:textColor="#888888" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Preferences / Units -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/cloud_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Units &amp; Logging"
                        android:textColor="@color/deep_sky_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Speed Units -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark_grey"
                        android:text="Speed"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgSpeedUnits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbSpeedKmh" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="km/h" android:checked="true"/>
                        <RadioButton android:id="@+id/rbSpeedKts" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Knots" />
                        <RadioButton android:id="@+id/rbSpeedMph" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="mph" />
                        <RadioButton android:id="@+id/rbSpeedMach" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mach" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="16dp"/>

                    <!-- Initial Zoom -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark_grey"
                        android:text="Initial Zoom"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgInitialZoom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbZoomFar" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Far (10x)" />
                        <RadioButton android:id="@+id/rbZoomMedium" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medium (14x)" />
                        <RadioButton android:id="@+id/rbZoomClose" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Close (18x)" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="16dp"/>

                    <!-- Altitude Units -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark_grey"
                        android:text="Altitude"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgAltUnits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbAltM" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Meters" android:checked="true"/>
                        <RadioButton android:id="@+id/rbAltFt" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Feet" />
                        <RadioButton android:id="@+id/rbAltKm" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kilometers (km)" />
                        <RadioButton android:id="@+id/rbAltBk" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Burj Khalifa (bk)" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="16dp"/>

                    <!-- Climb Rate Units -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark_grey"
                        android:text="Climb Rate"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgClimbUnits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RadioButton android:id="@+id/rbClimbMs" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m/s" android:checked="true"/>
                        <RadioButton android:id="@+id/rbClimbKmh" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="km/h" />
                        <RadioButton android:id="@+id/rbClimbFpm" android:textColor="#333333" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ft/min" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="16dp"/>

                    <!-- Logging Interval Units -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark_grey"
                        android:text="Route Logging Interval"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    
                    <RadioGroup
                        android:id="@+id/rgLoggingInterval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="5">
                        <RadioButton android:id="@+id/rbLog1s" android:textColor="#333333" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="1s" android:checked="true"/>
                        <RadioButton android:id="@+id/rbLog2s" android:textColor="#333333" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="2s" />
                        <RadioButton android:id="@+id/rbLog3s" android:textColor="#333333" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="3s" />
                        <RadioButton android:id="@+id/rbLog4s" android:textColor="#333333" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="4s" />
                        <RadioButton android:id="@+id/rbLog5s" android:textColor="#333333" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="5s" />
                    </RadioGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Guide Range Key -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/cloud_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Route Map Guide (Key)"
                        android:textColor="@color/deep_sky_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Altitude (Color):"
                        android:textColor="@color/text_dark_grey"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    
                    <!-- Replaced Solid Colors with Gradient -->
                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="12dp" 
                        android:background="@drawable/bg_gradient_altitude"
                        android:layout_marginBottom="4dp"/>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0m" android:textColor="#555555" android:textSize="12sp" android:gravity="start"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Med" android:textColor="#555555" android:textSize="12sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="High" android:textColor="#555555" android:textSize="12sp" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="10000+ ft" android:textColor="#555555" android:textSize="12sp" android:gravity="end"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Speed (Thickness):"
                        android:textColor="@color/text_dark_grey"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <View android:layout_width="40dp" android:layout_height="2dp" android:background="@color/sky_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Slower  " android:textColor="#555555" android:textSize="12sp"/>
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <View android:layout_width="60dp" android:layout_height="8dp" android:background="@color/deep_sky_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Faster" android:textColor="#555555" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Debug Mode -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/cloud_white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Advanced"
                        android:textColor="@color/deep_sky_blue"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <Switch
                        android:id="@+id/switchDebugMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Debug Mode (Raw Data &amp; Compass)"
                        android:textColor="@color/text_dark_grey"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>