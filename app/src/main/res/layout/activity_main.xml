<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <!-- The Map View -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- A Cyberpunk Overlay for the Map (slight vignette/vibration) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A0FFFFF"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Top Settings Button (Neon Style) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/ic_settings_neon"
        app:backgroundTint="#111111"
        app:borderWidth="1dp"
        app:elevation="12dp"
        app:fabSize="normal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@null" />

    <!-- Bottom Telemetry Dashboard (Cyberpunk Glassmorphism) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/telemetryDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="24dp"
        android:background="#DD000000"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        
        <!-- Neon Border simulation -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="8dp"
            android:weightSum="5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- SPEED -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.2"
                    android:text="VEL"
                    android:textColor="#0FFFFF"
                    android:fontFamily="monospace"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="000"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ALTITUDE -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.2"
                    android:text="ALT"
                    android:textColor="#FF00FF"
                    android:fontFamily="monospace"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvAlt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="000"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- HEADING -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.2"
                    android:text="HDG"
                    android:textColor="#0FFFFF"
                    android:fontFamily="monospace"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="000°"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- CLIMB -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.2"
                    android:text="VRT"
                    android:textColor="#FF00FF"
                    android:fontFamily="monospace"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvClimb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- PITCH -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.2"
                    android:text="PCH"
                    android:textColor="#0FFFFF"
                    android:fontFamily="monospace"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/tvClimbAngle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0°"
                    android:textColor="#FFFFFF"
                    android:fontFamily="monospace"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Recenter Button (Bottom Right, Above Telemetry) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_recenter_neon"
        app:backgroundTint="#111111"
        app:borderWidth="1dp"
        app:elevation="12dp"
        app:fabSize="mini"
        app:layout_constraintBottom_toTopOf="@+id/telemetryDashboard"
        app:layout_constraintEnd_toEndOf="@+id/telemetryDashboard"
        app:tint="@null" />

    <!-- Debug Mode Panel (Sci-Fi Hud style) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardDebugMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        android:visibility="gone"
        android:background="#BB000000"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">
                <TextView android:id="@+id/tvDebugLatLon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#0FFFFF" android:textSize="8sp" android:text="LAT: -- \nLON: --" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvDebugAcc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF00FF" android:textSize="8sp" android:text="ACC: --" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvDebugRawSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#0FFFFF" android:textSize="8sp" android:text="SPD: --" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvDebugRawAlt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF00FF" android:textSize="8sp" android:text="ALT: --" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvDebugBearing" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#0FFFFF" android:textSize="8sp" android:text="BRG: --" android:fontFamily="monospace"/>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="60dp"
                android:layout_height="60dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="N" android:textColor="#0FFFFF" android:textSize="8sp" android:layout_alignParentTop="true" android:layout_centerHorizontal="true" android:fontFamily="monospace"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="#FF00FF" android:textSize="8sp" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true" android:fontFamily="monospace"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:textColor="#FFFFFF" android:textSize="8sp" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:fontFamily="monospace"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E" android:textColor="#FFFFFF" android:textSize="8sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:fontFamily="monospace"/>
                
                <ImageView
                    android:id="@+id/ivCompassArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_recenter_neon"
                    app:tint="#FF00FF"/>
            </RelativeLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>