<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".MainActivity">

    <!-- The Map View -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Telemetry Dashboard (Translucent) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/telemetryDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/translucent_white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="5">

            <!-- SPEED -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPEED"
                    android:textColor="@color/text_dark_grey"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="--"
                    android:textColor="@color/deep_sky_blue"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- ALTITUDE -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALT"
                    android:textColor="@color/text_dark_grey"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvAlt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="--"
                    android:textColor="@color/deep_sky_blue"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- HEADING -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HDG"
                    android:textColor="@color/text_dark_grey"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="--"
                    android:textColor="@color/deep_sky_blue"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- CLIMB -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLIMB"
                    android:textColor="@color/text_dark_grey"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvClimb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="--"
                    android:textColor="@color/deep_sky_blue"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- CLIMB ANGLE -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANG"
                    android:textColor="@color/text_dark_grey"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvClimbAngle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="--"
                    android:textColor="@color/deep_sky_blue"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Mode Indicator (bottom left) -->
    <TextView
        android:id="@+id/tvModeIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/mode_chip_bg"
        android:text="PLANE"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Side Action Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Add Note FAB (only visible during recording) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_add_note"
            android:visibility="gone"
            app:backgroundTint="@color/accent_yellow"
            app:elevation="2dp"
            app:fabSize="mini"
            app:tint="@color/white" />

        <!-- Record/Pause FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRecord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_media_play"
            app:backgroundTint="@color/translucent_white"
            app:elevation="0dp"
            app:fabSize="normal"
            app:tint="@color/deep_sky_blue" />

        <!-- Menu FAB (hamburger icon) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_menu"
            app:backgroundTint="@color/translucent_white"
            app:elevation="0dp"
            app:fabSize="normal"
            app:tint="@color/deep_sky_blue" />

        <!-- Location FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="@color/translucent_white"
            app:elevation="0dp"
            app:fabSize="normal"
            app:tint="@color/deep_sky_blue" />
    </LinearLayout>

    <!-- Debug Mode Panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDebugMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/translucent_white"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView android:id="@+id/tvDebugLatLon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_dark_grey" android:textSize="10sp" android:text="Lat: -- \nLon: --" />
                <TextView android:id="@+id/tvDebugAcc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_dark_grey" android:textSize="10sp" android:text="Acc: --" />
                <TextView android:id="@+id/tvDebugRawSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_dark_grey" android:textSize="10sp" android:text="Speed (m/s): --" />
                <TextView android:id="@+id/tvDebugRawAlt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_dark_grey" android:textSize="10sp" android:text="Alt (m): --" />
                <TextView android:id="@+id/tvDebugBearing" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_dark_grey" android:textSize="10sp" android:text="Bearing: --" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="80dp"
                android:layout_height="80dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="N 0" android:textColor="@color/text_dark_grey" android:textSize="8sp" android:layout_alignParentTop="true" android:layout_centerHorizontal="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S 180" android:textColor="@color/text_dark_grey" android:textSize="8sp" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W 270" android:textColor="@color/text_dark_grey" android:textSize="8sp" android:layout_alignParentStart="true" android:layout_centerVertical="true"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E 90" android:textColor="@color/text_dark_grey" android:textSize="8sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
                
                <ImageView
                    android:id="@+id/ivCompassArrow"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerInParent="true"
                    android:src="@android:drawable/arrow_up_float"
                    app:tint="@color/deep_sky_blue"/>
            </RelativeLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>