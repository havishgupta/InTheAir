<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:paddingStart="24dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/ivNoteIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_note_marker"
        android:layout_marginEnd="12dp"
        android:contentDescription="Note icon"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNoteText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Note text"
            android:textColor="@color/text_dark_grey"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvNoteTags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tags: General"
            android:textColor="@color/text_medium_grey"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivToggleVisibility"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_view_voyage"
        android:tint="@color/deep_sky_blue"
        android:padding="2dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Toggle visibility"/>

    <ImageView
        android:id="@+id/ivEditNote"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_rename"
        android:tint="@color/text_dark_grey"
        android:padding="2dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Edit note"/>

    <ImageView
        android:id="@+id/ivDeleteNote"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_delete"
        android:tint="@color/red_error"
        android:padding="2dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Delete note"/>

</LinearLayout>
