<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingTop="12dp"
    android:paddingBottom="24dp"
    android:paddingHorizontal="20dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/divider_grey" />

    <!-- Saved Voyages Menu Item -->
    <LinearLayout
        android:id="@+id/menuItemVoyages"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@drawable/menu_item_bg"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_voyage"
            android:tint="@color/deep_sky_blue"
            android:layout_marginEnd="16dp"
            android:contentDescription="Voyages icon"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voyages"
            android:textColor="@color/text_dark_grey"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_grey" />

    <!-- Offline Maps Menu Item -->
    <LinearLayout
        android:id="@+id/menuItemOfflineMaps"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@drawable/menu_item_bg"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_cloud"
            android:tint="@color/deep_sky_blue"
            android:layout_marginEnd="16dp"
            android:contentDescription="Offline Maps icon"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offline Maps"
            android:textColor="@color/text_dark_grey"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_grey" />

    <!-- Global Notes Menu Item -->
    <LinearLayout
        android:id="@+id/menuItemNotes"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@drawable/menu_item_bg"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_note_marker"
            android:tint="@color/deep_sky_blue"
            android:layout_marginEnd="16dp"
            android:contentDescription="Global Notes icon"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notes"
            android:textColor="@color/text_dark_grey"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_grey" />

    <!-- Settings Menu Item -->
    <LinearLayout
        android:id="@+id/menuItemSettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@drawable/menu_item_bg"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_gear"
            android:tint="@color/text_medium_grey"
            android:layout_marginEnd="16dp"
            android:contentDescription="Settings icon"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_medium_grey"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</LinearLayout>
