<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Stealth Bomber Silhouette -->
    <!-- Base shadow / trail -->
    <path
        android:fillColor="#66FF00FF"
        android:pathData="M100,40 L160,140 L100,120 L40,140 Z"/>
    
    <!-- Main Hull -->
    <path
        android:fillColor="#111111"
        android:strokeColor="#0FFFFF"
        android:strokeWidth="4"
        android:pathData="M100,20 L180,160 L140,160 L100,130 L60,160 L20,160 Z"/>
    
    <!-- Cockpit -->
    <path
        android:fillColor="#FF00FF"
        android:pathData="M100,40 L110,80 L90,80 Z"/>

    <!-- Thruster glow -->
    <path
        android:fillColor="#0FFFFF"
        android:pathData="M80,145 L120,145 L100,190 Z"/>
</vector>